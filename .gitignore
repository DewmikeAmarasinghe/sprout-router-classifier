# ── Dataset files ─────────────────────────────────────────────────────────────
#
# COMMITTED (train/val/test CSVs are small and needed for Kaggle):
#   data/datasets/*/train.csv
#   data/datasets/*/val.csv
#   data/datasets/*/test.csv
#   data/datasets/*/split_stats.json
#   data/grounding/unicode_verification.csv
#   src/backend/generation/examples.json
#
# IGNORED (large intermediate files, regeneratable):
data/datasets/*/raw/checkpoint.csv
data/datasets/*/raw/generated_raw.csv

# ── Model artifacts ───────────────────────────────────────────────────────────
#
# NOT committed — download from Kaggle Outputs tab after training.
# Classical .pkl files: 5-100MB each. Transformer checkpoints: 500MB-2GB each.
# Both exceed GitHub's 100MB per-file limit for realistic training runs.
#
# Download workflow:
#   Kaggle session → Outputs tab → experiments/ → Download zip
#   Extract: cp -r /tmp/kaggle_out/experiments/* ./experiments/
#
# If you want git-based transfer, set up Git LFS:
#   git lfs install
#   git lfs track "*.pkl" "*.bin" "*.safetensors" "*.pt"
#   git add .gitattributes && git commit -m "Track large files with LFS"

experiments/*/classical/models/
experiments/*/transformers/models/

# ── Results and graphs — COMMITTED ────────────────────────────────────────────
#
# These are small and valuable. Commit them so the team can see results.
#   experiments/*/master_comparison.csv     ← model comparison table
#   experiments/*/cost_simulation.json      ← cost analysis
#   experiments/*/ablation_results.json     ← ablation study
#   experiments/*/error_analysis.json       ← false negative breakdown
#   experiments/*/router_config.json        ← tuned threshold
#   experiments/*/split_stats.json
#   experiments/*/eda_plots/                ← PNG plots from phase_4
#   experiments/*/classical/results/        ← per-experiment metrics CSV
#   experiments/*/transformers/results/     ← transformer metrics CSV
# (nothing to add here — they're tracked by default since models/ is ignored)

# ── CatBoost training info ────────────────────────────────────────────────────
catboost_info/

